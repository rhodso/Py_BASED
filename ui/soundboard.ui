<?xml version='1.0' encoding='utf-8'?>
<interface version="1.3">
  <object class="tk.Toplevel" id="soundboard_toplevel" named="True">
    <property name="height">200</property>
    <property name="title" translatable="yes">BASED-Soundboard</property>
    <property name="width">200</property>
    <child>
      <object class="ttk.Frame" id="header_frame" named="True">
        <property name="height">200</property>
        <property name="width">200</property>
        <layout manager="pack">
          <property name="side">top</property>
        </layout>
        <child>
          <object class="ttk.Label" id="header_label" named="True">
            <property name="font">{Arial} 12 {bold}</property>
            <property name="text" translatable="yes">BASED</property>
            <layout manager="pack">
              <property name="side">top</property>
            </layout>
          </object>
        </child>
        <child>
          <object class="ttk.Label" id="caption_label" named="True">
            <property name="font">{Arial} 7 {italic}</property>
            <property name="text" translatable="yes">Broadcast Automation System for Electronic Devices</property>
            <layout manager="pack">
              <property name="side">top</property>
            </layout>
          </object>
        </child>
      </object>
    </child>
    <child>
      <object class="ttk.Frame" id="search_frame" named="True">
        <property name="height">200</property>
        <property name="width">200</property>
        <layout manager="pack">
          <property name="pady">5</property>
          <property name="side">top</property>
        </layout>
        <child>
          <object class="ttk.Label" id="search_label" named="True">
            <property name="font">{Arial} 12 {}</property>
            <property name="text" translatable="yes">Search:</property>
            <layout manager="pack">
              <property name="side">left</property>
            </layout>
          </object>
        </child>
        <child>
          <object class="ttk.Entry" id="search_entry" named="True">
            <property name="takefocus">true</property>
            <property name="width">25</property>
            <layout manager="pack">
              <property name="side">top</property>
            </layout>
          </object>
        </child>
      </object>
    </child>
    <child>
      <object class="ttk.Separator" id="separator_1">
        <property name="orient">horizontal</property>
        <layout manager="pack">
          <property name="fill">x</property>
          <property name="side">top</property>
        </layout>
      </object>
    </child>
    <child>
      <object class="ttk.Frame" id="board_outer_frame" named="True">
        <property name="height">200</property>
        <property name="width">200</property>
        <layout manager="pack">
          <property name="fill">x</property>
          <property name="side">top</property>
        </layout>
        <child>
          <object class="pygubu.builder.widgets.scrolledframe" id="board_scrollframe" named="True">
            <property name="scrolltype">vertical</property>
            <property name="usemousewheel">true</property>
            <property name="width">250</property>
            <layout manager="pack">
              <property name="fill">x</property>
              <property name="side">top</property>
            </layout>
            <child>
              <object class="ttk.Frame" id="board_frame" named="True">
                <property name="height">200</property>
                <property name="width">250</property>
                <layout manager="pack">
                  <property name="anchor">center</property>
                  <property name="side">top</property>
                </layout>
                <child>
                  <object class="ttk.Button" id="button_8">
                    <property name="text" translatable="yes">button</property>
                    <layout manager="place">
                      <property name="anchor">nw</property>
                      <property name="height">50</property>
                      <property name="width">50</property>
                      <property name="x">0</property>
                      <property name="y">0</property>
                    </layout>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </child>
      </object>
    </child>
    <child>
      <object class="ttk.Frame" id="control_frame" named="True">
        <property name="height">200</property>
        <property name="width">200</property>
        <layout manager="pack">
          <property name="side">top</property>
        </layout>
        <child>
          <object class="ttk.Button" id="add_button" named="True">
            <property name="text" translatable="yes">Add</property>
            <layout manager="grid">
              <property name="column">0</property>
              <property name="row">0</property>
            </layout>
          </object>
        </child>
        <child>
          <object class="ttk.Label" id="label_2">
            <property name="text" translatable="yes">    </property>
            <layout manager="grid">
              <property name="column">1</property>
              <property name="row">0</property>
            </layout>
          </object>
        </child>
        <child>
          <object class="ttk.Checkbutton" id="edit_mode_label" named="True">
            <property name="text" translatable="yes">Edit Mode</property>
            <layout manager="grid">
              <property name="column">2</property>
              <property name="row">0</property>
            </layout>
          </object>
        </child>
        <child>
          <object class="ttk.Label" id="label_3">
            <property name="text" translatable="yes">    </property>
            <layout manager="grid">
              <property name="column">4</property>
              <property name="row">0</property>
            </layout>
          </object>
        </child>
        <child>
          <object class="ttk.Button" id="delete_button" named="True">
            <property name="text" translatable="yes">Delete</property>
            <layout manager="grid">
              <property name="column">5</property>
              <property name="row">0</property>
            </layout>
          </object>
        </child>
      </object>
    </child>
  </object>
</interface>
