<?xml version='1.0' encoding='utf-8'?>
<interface version="1.3">
  <object class="tk.Toplevel" id="toplevel_1">
    <property name="height">200</property>
    <property name="width">250</property>
    <child>
      <object class="ttk.Frame" id="header_frame" named="True">
        <property name="height">200</property>
        <property name="width">250</property>
        <layout manager="pack">
          <property name="expand">true</property>
          <property name="fill">x</property>
          <property name="side">top</property>
        </layout>
        <child>
          <object class="ttk.Label" id="header_label" named="True">
            <property name="font">{Arial} 12 {bold}</property>
            <property name="text" translatable="yes">BASED</property>
            <layout manager="pack">
              <property name="side">top</property>
            </layout>
          </object>
        </child>
        <child>
          <object class="ttk.Label" id="caption_label" named="True">
            <property name="font">{Arial} 7 {italic}</property>
            <property name="text" translatable="yes">Broadcast Automation System for Electronic Devices</property>
            <layout manager="pack">
              <property name="side">top</property>
            </layout>
          </object>
        </child>
      </object>
    </child>
    <child>
      <object class="ttk.Frame" id="frame_1">
        <property name="height">200</property>
        <property name="width">250</property>
        <layout manager="pack">
          <property name="side">top</property>
        </layout>
        <child>
          <object class="ttk.Label" id="label_1">
            <property name="font">{Arial} 12 {}</property>
            <property name="text" translatable="yes">Add New Soundboard Button</property>
            <layout manager="pack">
              <property name="side">top</property>
            </layout>
          </object>
        </child>
        <child>
          <object class="ttk.Separator" id="separator_1">
            <property name="orient">horizontal</property>
            <layout manager="pack">
              <property name="expand">false</property>
              <property name="fill">x</property>
              <property name="side">top</property>
            </layout>
          </object>
        </child>
        <child>
          <object class="ttk.Frame" id="frame_2">
            <property name="height">200</property>
            <property name="width">250</property>
            <layout manager="pack">
              <property name="side">top</property>
            </layout>
            <child>
              <object class="ttk.Label" id="name_label" named="True">
                <property name="text" translatable="yes">Sound Name</property>
                <layout manager="grid">
                  <property name="column">0</property>
                  <property name="row">0</property>
                </layout>
              </object>
            </child>
            <child>
              <object class="ttk.Entry" id="name_entry" named="True">
                <property name="width">26</property>
                <layout manager="grid">
                  <property name="column">1</property>
                  <property name="columnspan">2</property>
                  <property name="row">0</property>
                </layout>
              </object>
            </child>
            <child>
              <object class="ttk.Label" id="imagefp_name_label" named="True">
                <property name="compound">top</property>
                <property name="font">TkMenuFont</property>
                <property name="text" translatable="yes">Image FP</property>
                <layout manager="grid">
                  <property name="column">0</property>
                  <property name="row">1</property>
                </layout>
              </object>
            </child>
            <child>
              <object class="pygubu.builder.widgets.pathchooserinput" id="pathchooserinput_1">
                <property name="mustexist">true</property>
                <property name="type">file</property>
                <layout manager="grid">
                  <property name="column">1</property>
                  <property name="row">1</property>
                </layout>
              </object>
            </child>
            <child>
              <object class="ttk.Labelframe" id="labelframe_2">
                <property name="height">200</property>
                <property name="text" translatable="yes">TTS Soundboard Entry</property>
                <property name="width">250</property>
                <layout manager="grid">
                  <property name="column">0</property>
                  <property name="columnspan">3</property>
                  <property name="row">3</property>
                </layout>
                <containerlayout manager="grid">
                  <property type="col" id="0" name="minsize">130</property>
                  <property type="col" id="0" name="pad">5</property>
                </containerlayout>
                <child>
                  <object class="ttk.Label" id="label_5">
                    <property name="text" translatable="yes">TTS Text</property>
                    <layout manager="grid">
                      <property name="column">0</property>
                      <property name="row">0</property>
                    </layout>
                  </object>
                </child>
                <child>
                  <object class="ttk.Entry" id="entry_3">
                    <property name="width">20</property>
                    <layout manager="grid">
                      <property name="column">1</property>
                      <property name="columnspan">2</property>
                      <property name="row">0</property>
                    </layout>
                  </object>
                </child>
              </object>
            </child>
            <child>
              <object class="ttk.Labelframe" id="labelframe_3">
                <property name="height">200</property>
                <property name="text" translatable="yes">File Soundboard Entry</property>
                <property name="width">200</property>
                <layout manager="grid">
                  <property name="column">0</property>
                  <property name="columnspan">3</property>
                  <property name="row">4</property>
                </layout>
                <containerlayout manager="grid">
                  <property type="col" id="0" name="minsize">90</property>
                  <property type="col" id="0" name="pad">5</property>
                </containerlayout>
                <child>
                  <object class="ttk.Label" id="label_6">
                    <property name="text" translatable="yes">SB Filepath</property>
                    <layout manager="grid">
                      <property name="column">0</property>
                      <property name="row">0</property>
                    </layout>
                  </object>
                </child>
                <child>
                  <object class="pygubu.builder.widgets.pathchooserinput" id="pathchooserinput_2">
                    <property name="mustexist">true</property>
                    <property name="type">file</property>
                    <layout manager="grid">
                      <property name="column">1</property>
                      <property name="row">0</property>
                    </layout>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </child>
      </object>
    </child>
    <child>
      <object class="ttk.Frame" id="frame_4">
        <property name="height">200</property>
        <property name="width">250</property>
        <layout manager="pack">
          <property name="side">top</property>
        </layout>
        <child>
          <object class="ttk.Button" id="cancel_button" named="True">
            <property name="command" type="command" cbtype="simple">cancel_button_action</property>
            <property name="text" translatable="yes">Cancel</property>
            <layout manager="grid">
              <property name="column">0</property>
              <property name="row">0</property>
            </layout>
          </object>
        </child>
        <child>
          <object class="ttk.Label" id="label_2">
            <property name="text" translatable="yes">                   </property>
            <layout manager="grid">
              <property name="column">1</property>
              <property name="row">0</property>
            </layout>
          </object>
        </child>
        <child>
          <object class="ttk.Button" id="button_2">
            <property name="command" type="command" cbtype="simple">add_button_action</property>
            <property name="text" translatable="yes">Add</property>
            <layout manager="grid">
              <property name="column">2</property>
              <property name="row">0</property>
            </layout>
          </object>
        </child>
      </object>
    </child>
  </object>
</interface>
